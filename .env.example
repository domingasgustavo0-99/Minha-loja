# Senha que você vai usar pra entrar no /admin
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Chave da API da Vye (pega em https://vyepay.com/dashboard/credentials)
VYEPAY_API_KEY=sua_chave_aqui

# URL do webhook do canal do Discord onde quer receber os avisos de venda
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# Preenchidos automaticamente pela Vercel quando você conectar o "KV" (Storage)
KV_REST_API_URL=
KV_REST_API_TOKEN=
